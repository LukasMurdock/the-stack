/**
 * Dedicated uptime Worker (service-bound).
 *
 * - Runs scheduled checks via Cron Triggers
 * - Stores latest status in KV
 * - Serves /uptime + /uptime.json (proxied/cached by the main Worker)
 */
{
	"$schema": "node_modules/wrangler/config-schema.json",
	"name": "the-stack-uptime-local",
	"main": "./src/uptime-worker.ts",
	"compatibility_date": "2025-10-08",
	"compatibility_flags": ["nodejs_compat"],
	"vars": {
		"APP_ENV": "local"
	},
	"kv_namespaces": [
		{
			"binding": "TURRET_UPTIME"
		}
	],
	"services": [
		{
			"binding": "APP",
			"service": "the-stack-local"
		}
	],
	"triggers": {
		"crons": ["*/5 * * * *"]
	},
	"env": {
		"production": {
			"name": "the-stack-uptime-production",
			"vars": {
				"APP_ENV": "production"
			},
			"kv_namespaces": [
				{
					"binding": "TURRET_UPTIME"
				}
			],
			"services": [
				{
					"binding": "APP",
					"service": "the-stack-production"
				}
			],
			"triggers": {
				"crons": ["*/5 * * * *"]
			}
		}
	}
}
