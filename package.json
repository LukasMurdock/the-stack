{
	"name": "the-stack",
	"description": "A Cloudflare Workers app template.",
	"cloudflare": {
		"label": "Cloudflare App Template",
		"products": [
			"Workers"
		],
		"categories": [],
		"publish": true
	},
	"scripts": {
		"build": "tsc -b && astro build",
		"check": "tsc && astro build && wrangler deploy --config wrangler.json --env production --dry-run",
		"deploy": "node -e \"console.error('Refusing to deploy without an env. Use: just deploy-production'); process.exit(1)\"",
		"dev": "astro dev",
		"lint": "eslint .",
		"prepare": "husky",
		"test": "tsx --test \"tests/**/*.test.ts\"",
		"preview": "npm run build && astro preview",
		"db:core:generate": "drizzle-kit generate --config src/bindings/d1/core/drizzle.config.ts",
		"db:turret:generate": "drizzle-kit generate --config src/bindings/d1/turret/drizzle.config.ts",
		"email:dev": "email dev",
		"format": "oxfmt --write .",
		"format:check": "oxfmt --check .",
		"db:local:squash": "rm -rf src/bindings/d1/core/drizzle/* && npm run db:core:generate && wrangler d1 migrations apply CORE_DB --local",
		"db:local:squash-turret": "rm -rf src/bindings/d1/turret/drizzle/* && npm run db:turret:generate && wrangler d1 migrations apply TURRET_DB --local"
	},
	"dependencies": {
		"@astrojs/cloudflare": "13.1.8",
		"@astrojs/react": "5.0.3",
		"@base-ui/react": "^1.4.0",
		"@hono/zod-openapi": "^1.3.0",
		"@react-email/components": "1.0.12",
		"@react-email/render": "2.0.6",
		"@scalar/hono-api-reference": "^0.10.7",
		"@tailwindcss/vite": "^4.2.2",
		"@tanstack/react-query": "^5.99.0",
		"@tanstack/react-router": "^1.168.19",
		"@tanstack/react-table": "^8.21.3",
		"astro": "6.1.5",
		"better-auth": "^1.6.2",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"cmdk": "^1.1.1",
		"date-fns": "^4.1.0",
		"dotenv": "^17.4.2",
		"drizzle-orm": "^0.45.2",
		"hono": "^4.12.12",
		"lucide-react": "^0.577.0",
		"react": "^19.2.5",
		"react-day-picker": "^9.14.0",
		"react-dom": "^19.2.5",
		"react-resizable-panels": "^4.10.0",
		"recharts": "^3.8.1",
		"resend": "^6.10.0",
		"rrweb": "^2.0.0-alpha.4",
		"rrweb-player": "^1.0.0-alpha.4",
		"tailwind-merge": "^3.5.0",
		"tailwindcss": "^4.2.2",
		"vaul": "^1.1.2",
		"zod": "^4.3.6"
	},
	"devDependencies": {
		"@cloudflare/vite-plugin": "^1.31.2",
		"@eslint/js": "^9.39.4",
		"@react-email/preview-server": "5.2.10",
		"@tanstack/eslint-plugin-query": "^5.99.0",
		"@tanstack/eslint-plugin-router": "^1.161.6",
		"@tanstack/react-query-devtools": "^5.99.0",
		"@tanstack/react-router-devtools": "^1.166.13",
		"@tanstack/router-plugin": "^1.167.20",
		"@types/node": "^25.6.0",
		"@types/react": "19.2.14",
		"@types/react-dom": "19.2.3",
		"better-sqlite3": "^12.9.0",
		"drizzle-kit": "^0.31.10",
		"eslint": "^9.39.4",
		"eslint-plugin-drizzle": "^0.2.3",
		"eslint-plugin-react-hooks": "7.0.1",
		"eslint-plugin-react-refresh": "0.5.2",
		"globals": "^17.5.0",
		"husky": "^9.1.7",
		"lint-staged": "^16.4.0",
		"oxfmt": "^0.44.0",
		"react-email": "5.2.10",
		"tsx": "^4.21.0",
		"tw-animate-css": "^1.4.0",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.58.1",
		"vite": "^7.3.1",
		"wrangler": "^4.76.0"
	},
	"private": true,
	"type": "module",
	"lint-staged": {
		"*.{js,jsx,ts,tsx,mjs,cjs,json,yml,yaml,md,mdx,astro,css,scss,html}": "oxfmt --no-error-on-unmatched-pattern --write"
	}
}
